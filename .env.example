# Copy this file to .env and fill in your local keys.
# Never commit .env.

# Required for OpenAI provider
OPENAI_API_KEY=

# Optional for Anthropic / Claude provider
ANTHROPIC_API_KEY=

# Optional for OpenRouter provider/fallback
OPENROUTER_API_KEY=

# Workflow/model configuration
WARROOM_RESPONDENT_MODELS=openai_primary,openrouter_free, claude_primary
WARROOM_REVIEWER_MODELS=openai_primary,openrouter_free, claude_primary
WARROOM_SYNTHESIZER_MODEL=openai_primary
WARROOM_TITLE_MODEL=openai_fast
WARROOM_FALLBACK_MODEL=openai_fast
WARROOM_PROVIDER_TIMEOUT_SECONDS=60

# Optional model overrides
OPENAI_PRIMARY_MODEL=gpt-5.1
OPENAI_FAST_MODEL=gpt-5-mini
CLAUDE_PRIMARY_MODEL=claude-sonnet-4-20250514
CLAUDE_FAST_MODEL=claude-3-5-haiku-20241022
OPENROUTER_FREE_MODEL=openrouter/free
